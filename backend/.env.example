# =========================
# 基础运行配置
# =========================
# 运行环境：development / production
APP_ENV=development
# 后端监听端口（部署时常用 8081 或 80/443 前的反向代理端口）
HTTP_PORT=8081
# PostgreSQL 连接串（生产环境请使用强密码，并按实际主机修改）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/xiuxian?sslmode=disable
# Redis 连接串（当前主要用于缓存/会话扩展能力）
REDIS_URL=redis://localhost:6379/0
# 数据库迁移文件目录（通常保持默认）
MIGRATIONS_DIR=./migrations

# =========================
# 鉴权与会话配置
# =========================
# JWT 密钥（生产环境务必替换为高强度随机字符串）
JWT_SECRET=change-me
# AccessToken 有效期（秒）
ACCESS_TOKEN_TTL_SECONDS=3600
# RefreshToken 有效期（秒）
REFRESH_TOKEN_TTL_SECONDS=604800
# OAuth state 有效期（秒）
OAUTH_STATE_TTL_SECONDS=600
# 是否开启开发者一键登录（生产环境建议 false）
ENABLE_DEV_LOGIN=true

# =========================
# 拍卖系统定时清理配置
# =========================
# 清理过期订单的执行间隔（秒）
AUCTION_SWEEP_INTERVAL_SECONDS=60
# 每次清理的最大订单数
AUCTION_SWEEP_BATCH_SIZE=100

# =========================
# 聊天系统配置
# =========================
# 聊天管理员 Linux.do 用户 ID 列表（英文逗号分隔）
CHAT_ADMIN_USER_IDS="dev-e25f9aa0-11bb-455e-a22c-96ce58a85cd7"
# 聊天自动清理执行间隔（秒）
CHAT_CLEANUP_INTERVAL_SECONDS=30
# 聊天保留时长（秒，默认 600=10 分钟）
CHAT_RETENTION_SECONDS=600
# 聊天最多保留条数（超过会删除最早消息）
CHAT_RETENTION_MAX_MESSAGES=500

# =========================
# 充值系统配置
# =========================
# 是否启用“模拟支付”能力（生产环境建议 false）
ENABLE_RECHARGE_MOCK=true
# Linux.do Credit EasyPay Client ID（控制台创建 API Key 后获得）
RECHARGE_EPAY_PID=
# Linux.do Credit EasyPay Client Secret（控制台创建 API Key 后获得）
RECHARGE_EPAY_KEY=
# Linux.do Credit 网关地址
RECHARGE_EPAY_BASE_URL=https://credit.linux.do/epay
# 可选：参与签名的 notify_url（不会覆盖控制台设置的 notify_url）
RECHARGE_NOTIFY_URL=
# 可选：参与签名的 return_url（不会覆盖控制台设置的 return_url）
RECHARGE_RETURN_URL=
# 兼容旧配置：若 RECHARGE_EPAY_KEY 为空，会回退使用此值
RECHARGE_CALLBACK_SECRET=

# =========================
# Linux.do OAuth2 配置
# =========================
# Linux.do 应用 Client ID
LINUX_DO_CLIENT_ID=
# Linux.do 应用 Client Secret
LINUX_DO_CLIENT_SECRET=
# Linux.do OAuth 回调地址（必须与 Linux.do 应用后台配置一致）
LINUX_DO_REDIRECT_URL=http://localhost:8081/api/v1/auth/linux-do/callback
# Linux.do 授权地址（一般无需修改）
LINUX_DO_AUTHORIZE_URL=https://linux.do/oauth2/authorize
# Linux.do Token 地址（一般无需修改）
LINUX_DO_TOKEN_URL=https://linux.do/oauth2/token
# Linux.do 用户信息地址（一般无需修改）
LINUX_DO_USERINFO_URL=https://linux.do/api/user
# OAuth Scope（默认即可）
LINUX_DO_SCOPE=openid profile

# =========================
# 前端登录回跳地址
# =========================
# 登录成功后前端跳转地址
FRONTEND_LOGIN_SUCCESS_URL=http://localhost:2025/#/auth/callback
# 登录失败后前端跳转地址
FRONTEND_LOGIN_FAILURE_URL=http://localhost:2025/#/auth/callback
